import { Options } from '@mikro-orm/core';
import { PostgreSqlDriver } from '@mikro-orm/postgresql'; // Update if using mysql/mongodb

const mikroOrmConfig: Options = {
  type: '<%= databaseDriver === "pg" ? "postgresql" : databaseDriver %>' as any,
  host: process.env.DATABASE_HOST || 'localhost',
  port: parseInt(process.env.DATABASE_PORT || '<%= databasePort %>', 10),
  user: process.env.DATABASE_USER || 'postgres',
  password: process.env.DATABASE_PASSWORD || 'postgres',
  dbName: process.env.DATABASE_NAME || '<%= projectNameConstant %>_db',
  entities: ['dist/**/*.entity.js'],
  entitiesTs: ['src/**/*.entity.ts'],
  debug: process.env.NODE_ENV === 'development',
};

export default mikroOrmConfig;
