{
  "name": "nest-pilot",
  "private": true,
  "license": "MIT",
  "workspaces": [
    "cli"
  ],
  "scripts": {
    "build": "npm run build --workspace=cli",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write \"**/*.{ts,json,md}\"",
    "test": "npm run test --workspace=cli",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^19.x",
    "@commitlint/config-conventional": "^19.x",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^7.x",
    "@typescript-eslint/parser": "^7.x",
    "eslint": "^8.x",
    "eslint-config-prettier": "^9.x",
    "husky": "^9.x",
    "lint-staged": "^15.x",
    "prettier": "^3.x",
    "typescript": "~5.5.0",
    "uuid": "^13.0.0"
  }
}
