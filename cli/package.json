{
  "name": "nest-pilot",
  "version": "0.2.2",
  "description": "Interactive CLI for generating NestJS projects with Hexagonal, DDD, or Modular architecture",
  "author": "Mehedi Hasan",
  "license": "MIT",
  "keywords": [
    "nestjs",
    "cli",
    "boilerplate",
    "hexagonal-architecture",
    "typescript",
    "scaffold"
  ],
  "bin": {
    "nest-pilot": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json && node copy-templates.js",
    "dev": "tsx src/index.ts",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "ejs": "^3.1.10",
    "fs-extra": "^11.2.0"
  },
  "devDependencies": {
    "@types/ejs": "^3.1.5",
    "@types/fs-extra": "^11.0.4",
    "@types/jest": "^29.5.12",
    "@types/node": "^20.12.0",
    "@typescript-eslint/eslint-plugin": "^7.6.0",
    "@typescript-eslint/parser": "^7.6.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "jest": "^29.7.0",
    "prettier": "^3.2.5",
    "ts-jest": "^29.1.2",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.spec.ts"
    ],
    "moduleFileExtensions": [
      "ts",
      "js",
      "json"
    ],
    "moduleNameMapper": {
      "^chalk$": "<rootDir>/__mocks__/chalk.js",
      "^@clack/prompts$": "<rootDir>/__mocks__/@clack/prompts.js"
    }
  }
}
